{
    "manifest_version": 3,
    "name": "Stealth Ad & Tracker Blocker",
    "version": "2.0",
    "description": "Blocks ads, popups, trackers, cookie banners, social trackers, and malvertising with dynamic DOM observation and live statistics.",
    "permissions": [
        "storage",
        "declarativeNetRequest",
        "tabs",
        "contextMenus"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "options_page": "options.html",
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_start",
            "all_frames": true
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "replacement/cat.jpg",
                "replacement/dog.jpg",
                "replacement/nature.jpg"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}